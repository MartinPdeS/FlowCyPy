# .coveragerc
[run]
source = FlowCyPy
branch = True
relative_files = True
parallel = True
omit =
    **/__init__.py
    FlowCyPy/_version.py
    FlowCyPy/directories.py
    FlowCyPy/**/__main__.py
    FlowCyPy/gui/**
    FlowCyPy/_utils.py

[report]
skip_covered = True
show_missing = True
precision = 2

[html]
directory = htmlcov

[xml]
output = coverage.xml

[paths]
source =
    FlowCyPy
    /home/runner/work/FlowCyPy/FlowCyPy/FlowCyPy
    /github/workspace/FlowCyPy
